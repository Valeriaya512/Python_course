   "source": [
    "# 學生總分為300\n",
    "# 有些學生可以加分5%\n",
    "\n",
    "scores = int(input(\"請輸入學生分數(最高300分):\"))\n",
    "is_add = input(\"學生是否符合加分條件?(y,n)\")\n",
    "\n",
    "if is_add == \"y\":   #單向選擇\n",
    "    scores = scores * 1.05\n",
    "\n",
    "# 四捨五入(5進位)\n",
    "scores = int(scores + 0.5)\n",
    "\n",
    "print(\"學生分數:\", scores)"
   ]
  }
 ],
